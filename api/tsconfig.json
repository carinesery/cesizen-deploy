{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2020",
    "esModuleInterop": true,
    "types": ["node"],
    "lib": ["ES2020"],
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
  },
   "exclude": ["vitest.config.ts", "node_modules"]
}